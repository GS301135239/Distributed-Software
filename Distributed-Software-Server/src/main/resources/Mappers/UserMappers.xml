<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="org.example.distributedsoftwareserver.Mapper.UserMapper">
    <resultMap id="userResultMap" type="org.example.distributedsoftwareserver.Entity.Model.User">
        <id column="userID" property="userID"/>
        <result column="userPhone" property="userPhone"/>
        <result column="userName" property="userName"/>
        <result column="password" property="password"/>
        <result column="is_Login" property="is_Login"/>
    </resultMap>

    <insert id="insertUser" parameterType="org.example.distributedsoftwareserver.Entity.Model.User">
        INSERT INTO User (userPhone, userName, password, is_Login)
        VALUES (#{userPhone}, #{userName}, #{password}, #{is_Login})
    </insert>
    
    <select id="selectUserByUserPhone" parameterType="String" resultMap="userResultMap">
        SELECT * FROM User WHERE userPhone = #{userPhone}
    </select>
    
    <update id="updateUserLoginStatus" parameterType="org.example.distributedsoftwareserver.Entity.Model.User">
        UPDATE User SET is_Login = #{is_Login} WHERE userPhone = #{userPhone}
    </update>
</mapper>